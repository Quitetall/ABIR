{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quitetall.org/abir/schema/adapter-profile-v1.schema.json",
  "title": "ABIR Adapter profile registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profiles"],
  "properties": {
    "schema_version": {"const": 1},
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "standard", "edition", "media_types", "status", "validator", "capabilities"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$"},
          "standard": {"type": "string", "minLength": 1},
          "edition": {"type": "string", "minLength": 1},
          "media_types": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[^/\\s]+/[^\\s]+$"}, "uniqueItems": true},
          "status": {"enum": ["forensic", "semantic", "stream", "hardware"]},
          "validator": {"type": "string", "minLength": 1},
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["inspect", "import", "plan-export", "export", "validate", "stream", "hardware"]}
          }
        }
      }
    }
  }
}
