{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quitetall.org/abir/schema/training-snapshot-v1.schema.json",
  "title": "ABIR sealed training snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_roots",
    "decision_log_id",
    "profile",
    "rows",
    "schema",
    "sealed",
    "spec_id"
  ],
  "properties": {
    "dataset_roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/contentId" }
    },
    "decision_log_id": { "$ref": "#/$defs/contentId" },
    "profile": {
      "enum": ["speed", "balanced", "memory", "compact", "ultra-compact", "stream"]
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "schema": { "const": "org.quitetall.abir.training.snapshot-v1" },
    "sealed": { "const": true },
    "spec_id": { "$ref": "#/$defs/contentId" }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "label", "logical_bytes", "logical_id", "payload", "element", "shape", "split"],
      "properties": {
        "group": { "$ref": "#/$defs/contentId" },
        "label": { "$ref": "#/$defs/contentId" },
        "logical_bytes": { "type": "integer", "minimum": 1 },
        "logical_id": { "$ref": "#/$defs/contentId" },
        "payload": { "$ref": "#/$defs/contentId" },
        "element": {
          "enum": ["i8", "i16", "i24", "i32", "i64", "u8", "u16", "u32", "u64", "f16", "f32", "f64", "bool", "utf8", "bytes"]
        },
        "shape": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        },
        "split": { "$ref": "#/$defs/contentId" }
      }
    }
  }
}
