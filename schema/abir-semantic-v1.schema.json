{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Quitetall/ABIR/schema/abir-semantic-v1.schema.json",
  "title": "ABIR semantic-v1 canonical debug document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "semantic_version", "dataset_id", "subjects", "patients", "sessions",
    "acquisitions", "devices", "sensors", "channels", "concept_dictionaries", "source_relationships",
    "recordings", "streams", "atoms", "clocks", "clock_relations",
    "coordinate_frames", "frame_transforms", "channel_bases", "events",
    "policies", "proofs", "derivations", "derived_artifacts", "fidelity",
    "source_capsules", "observed_execution"
  ],
  "properties": {
    "semantic_version": { "const": "1" },
    "dataset_id": { "$ref": "#/$defs/object_id" },
    "subjects": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "patients": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "sessions": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "acquisitions": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "devices": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "sensors": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "channels": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "concept_dictionaries": { "type": "array", "items": { "$ref": "#/$defs/catalog_record" } },
    "source_relationships": { "type": "array", "items": { "$ref": "#/$defs/source_relationship" } },
    "recordings": {
      "type": "array",
      "items": { "$ref": "#/$defs/recording" }
    },
    "streams": { "type": "array", "items": { "$ref": "#/$defs/stream" } },
    "atoms": {
      "type": "array",
      "items": { "$ref": "#/$defs/atom" }
    },
    "clocks": { "type": "array", "items": { "$ref": "#/$defs/clock" } },
    "clock_relations": { "type": "array", "items": { "$ref": "#/$defs/clock_relation" } },
    "coordinate_frames": { "type": "array", "items": { "$ref": "#/$defs/coordinate_frame" } },
    "frame_transforms": { "type": "array", "items": { "$ref": "#/$defs/frame_transform" } },
    "channel_bases": { "type": "array", "items": { "$ref": "#/$defs/channel_basis" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
    "policies": { "type": "array", "items": { "$ref": "#/$defs/policy" } },
    "proofs": { "type": "array", "items": { "$ref": "#/$defs/proof" } },
    "derivations": { "type": "array", "items": { "$ref": "#/$defs/derivation" } },
    "derived_artifacts": { "type": "array", "items": { "$ref": "#/$defs/derived_artifact" } },
    "fidelity": { "type": "array", "items": { "$ref": "#/$defs/fidelity" } },
    "source_capsules": { "type": "array", "items": { "$ref": "#/$defs/source_capsule" } },
    "observed_execution": { "type": "array", "items": { "$ref": "#/$defs/execution" } }
  },
  "$defs": {
    "object_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "nullable_object_id": { "oneOf": [{ "$ref": "#/$defs/object_id" }, { "type": "null" }] },
    "content_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "concept": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]*:[A-Za-z0-9._/-]+$"
    },
    "i128_nonnegative": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,37}|(?:1[0-6][0-9]{37}|1700[0-9]{35}|1701[0-3][0-9]{34}|170140[0-9]{33}|1701410[0-9]{32}|1701411[0-7][0-9]{31}|17014118[0-2][0-9]{30}|170141183[0-3][0-9]{29}|1701411834[0-5][0-9]{28}|170141183460[0-3][0-9]{26}|1701411834604[0-5][0-9]{25}|17014118346046[0-8][0-9]{24}|170141183460469[0-1][0-9]{23}|1701411834604692[0-2][0-9]{22}|170141183460469230[0-9]{21}|170141183460469231[0-6][0-9]{20}|1701411834604692317[0-2][0-9]{19}|170141183460469231730[0-9]{18}|170141183460469231731[0-5][0-9]{17}|1701411834604692317316[0-7][0-9]{16}|17014118346046923173168[0-6][0-9]{15}|170141183460469231731687[0-2][0-9]{14}|17014118346046923173168730[0-2][0-9]{12}|170141183460469231731687303[0-6][0-9]{11}|17014118346046923173168730370[0-9]{10}|17014118346046923173168730371[0-4][0-9]{9}|170141183460469231731687303715[0-7][0-9]{8}|1701411834604692317316873037158[0-7][0-9]{7}|17014118346046923173168730371588[0-3][0-9]{6}|1701411834604692317316873037158840[0-9]{5}|17014118346046923173168730371588410[0-4][0-9]{3}|170141183460469231731687303715884105[0-6][0-9]{2}|1701411834604692317316873037158841057[0-1][0-9]|17014118346046923173168730371588410572[0-6]|170141183460469231731687303715884105727))$"
    },
    "i128_negative": {
      "type": "string",
      "pattern": "^-(?:[1-9][0-9]{0,37}|(?:1[0-6][0-9]{37}|1700[0-9]{35}|1701[0-3][0-9]{34}|170140[0-9]{33}|1701410[0-9]{32}|1701411[0-7][0-9]{31}|17014118[0-2][0-9]{30}|170141183[0-3][0-9]{29}|1701411834[0-5][0-9]{28}|170141183460[0-3][0-9]{26}|1701411834604[0-5][0-9]{25}|17014118346046[0-8][0-9]{24}|170141183460469[0-1][0-9]{23}|1701411834604692[0-2][0-9]{22}|170141183460469230[0-9]{21}|170141183460469231[0-6][0-9]{20}|1701411834604692317[0-2][0-9]{19}|170141183460469231730[0-9]{18}|170141183460469231731[0-5][0-9]{17}|1701411834604692317316[0-7][0-9]{16}|17014118346046923173168[0-6][0-9]{15}|170141183460469231731687[0-2][0-9]{14}|17014118346046923173168730[0-2][0-9]{12}|170141183460469231731687303[0-6][0-9]{11}|17014118346046923173168730370[0-9]{10}|17014118346046923173168730371[0-4][0-9]{9}|170141183460469231731687303715[0-7][0-9]{8}|1701411834604692317316873037158[0-7][0-9]{7}|17014118346046923173168730371588[0-3][0-9]{6}|1701411834604692317316873037158840[0-9]{5}|17014118346046923173168730371588410[0-4][0-9]{3}|170141183460469231731687303715884105[0-6][0-9]{2}|1701411834604692317316873037158841057[0-1][0-9]|17014118346046923173168730371588410572[0-7]|170141183460469231731687303715884105728))$"
    },
    "i128": {
      "oneOf": [
        { "$ref": "#/$defs/i128_nonnegative" },
        { "$ref": "#/$defs/i128_negative" }
      ]
    },
    "rational": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$rational"],
      "properties": {
        "$rational": {
          "type": "array", "prefixItems": [
            { "$ref": "#/$defs/i128" },
            { "$ref": "#/$defs/i128_nonnegative", "not": { "const": "0" } }
          ], "items": false, "minItems": 2, "maxItems": 2
        }
      }
    },
    "exact": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["$integer"],
          "properties": { "$integer": { "$ref": "#/$defs/i128" } }
        },
        { "$ref": "#/$defs/rational" }
      ]
    },
    "source_key": {
      "type": "object", "additionalProperties": false,
      "required": ["namespace", "value"],
      "properties": { "namespace": { "type": "string", "minLength": 1 }, "value": { "type": "string" } }
    },
    "catalog_record": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "source_keys"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "kind": { "$ref": "#/$defs/concept" },
        "source_keys": { "type": "array", "items": { "$ref": "#/$defs/source_key" } }
      }
    },
    "source_relationship": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind", "patient_id", "subject_id"], "properties": { "kind": { "const": "patient-subject" }, "patient_id": { "$ref": "#/$defs/object_id" }, "subject_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "session_id", "subject_id"], "properties": { "kind": { "const": "session-subject" }, "session_id": { "$ref": "#/$defs/object_id" }, "subject_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "session_id", "patient_id"], "properties": { "kind": { "const": "session-patient" }, "session_id": { "$ref": "#/$defs/object_id" }, "patient_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "acquisition_id", "session_id"], "properties": { "kind": { "const": "acquisition-session" }, "acquisition_id": { "$ref": "#/$defs/object_id" }, "session_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "acquisition_id", "device_id"], "properties": { "kind": { "const": "acquisition-device" }, "acquisition_id": { "$ref": "#/$defs/object_id" }, "device_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "device_id", "sensor_id"], "properties": { "kind": { "const": "device-sensor" }, "device_id": { "$ref": "#/$defs/object_id" }, "sensor_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "sensor_id", "channel_id"], "properties": { "kind": { "const": "sensor-channel" }, "sensor_id": { "$ref": "#/$defs/object_id" }, "channel_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "acquisition_id", "recording_id"], "properties": { "kind": { "const": "acquisition-recording" }, "acquisition_id": { "$ref": "#/$defs/object_id" }, "recording_id": { "$ref": "#/$defs/object_id" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "channel_id", "basis_id", "position"], "properties": { "kind": { "const": "channel-basis-member" }, "channel_id": { "$ref": "#/$defs/object_id" }, "basis_id": { "$ref": "#/$defs/object_id" }, "position": { "type": "integer", "minimum": 0, "maximum": 4294967295 } } }
      ]
    },
    "recording": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "streams", "source_keys"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "streams": { "type": "array", "items": { "$ref": "#/$defs/object_id" } },
        "source_keys": { "type": "array", "items": { "$ref": "#/$defs/source_key" } }
      }
    },
    "stream": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "recording_id", "modality", "atoms", "clock_id", "channel_basis_id", "policy_id"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "recording_id": { "$ref": "#/$defs/object_id" },
        "modality": { "$ref": "#/$defs/concept" },
        "atoms": { "type": "array", "items": { "$ref": "#/$defs/object_id" } },
        "clock_id": { "$ref": "#/$defs/nullable_object_id" },
        "channel_basis_id": { "$ref": "#/$defs/nullable_object_id" },
        "policy_id": { "$ref": "#/$defs/nullable_object_id" }
      }
    },
    "payload": {
      "type": "object", "additionalProperties": false,
      "required": ["content_id", "logical_bytes", "element", "byte_order", "layout", "shape", "encoding", "media_type"],
      "properties": {
        "content_id": { "$ref": "#/$defs/content_id" },
        "logical_bytes": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
        "element": { "enum": ["i8", "i16", "i24", "i32", "i64", "u8", "u16", "u32", "u64", "f16", "f32", "f64", "bool", "utf8", "bytes"] },
        "byte_order": { "enum": ["little", "big", "not-applicable"] },
        "layout": {
          "oneOf": [
            { "enum": ["dense-row-major", "dense-column-major"] },
            {
              "type": "object", "additionalProperties": false, "required": ["ragged"],
              "properties": { "ragged": {
                "type": "object", "additionalProperties": false, "required": ["rows", "offsets"],
                "properties": { "rows": { "type": "integer", "minimum": 1, "maximum": 18446744073709551615 }, "offsets": { "$ref": "#/$defs/content_id" } }
              } }
            },
            {
              "type": "object", "additionalProperties": false, "required": ["sparse-coo"],
              "properties": { "sparse-coo": {
                "type": "object", "additionalProperties": false, "required": ["nonzero", "indices"],
                "properties": { "nonzero": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 }, "indices": { "$ref": "#/$defs/content_id" } }
              } }
            },
            {
              "type": "object", "additionalProperties": false, "required": ["sparse-csr"],
              "properties": { "sparse-csr": {
                "type": "object", "additionalProperties": false, "required": ["nonzero", "indptr", "indices"],
                "properties": {
                  "nonzero": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
                  "indptr": { "$ref": "#/$defs/content_id" },
                  "indices": { "$ref": "#/$defs/content_id" }
                }
              } }
            },
            {
              "type": "object", "additionalProperties": false, "required": ["bfp"],
              "properties": { "bfp": {
                "type": "object", "additionalProperties": false, "required": ["block_len", "mantissa_bits", "scales"],
                "properties": {
                  "block_len": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
                  "mantissa_bits": { "type": "integer", "minimum": 1, "maximum": 32 },
                  "scales": { "$ref": "#/$defs/content_id" }
                }
              } }
            }
          ]
        },
        "shape": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 } },
        "encoding": { "oneOf": [{ "$ref": "#/$defs/concept" }, { "type": "null" }] },
        "media_type": { "oneOf": [{ "type": "string", "pattern": "^[^/\\s]+/[^\\s]+$" }, { "type": "null" }] }
      }
    },
    "table_column": {
      "type": "object", "additionalProperties": false,
      "required": ["semantic", "element", "nullable"],
      "properties": {
        "semantic": { "$ref": "#/$defs/concept" },
        "element": { "enum": ["i8", "i16", "i24", "i32", "i64", "u8", "u16", "u32", "u64", "f16", "f32", "f64", "bool", "utf8", "bytes"] },
        "nullable": { "type": "boolean" }
      }
    },
    "semantic_axis": {
      "type": "object", "additionalProperties": false,
      "required": ["semantic", "extent"],
      "properties": {
        "semantic": { "$ref": "#/$defs/concept" },
        "extent": { "type": "integer", "minimum": 1, "maximum": 18446744073709551615 }
      }
    },
    "decoded_semantics": {
      "type": "object", "additionalProperties": false,
      "required": ["atom_kind", "element", "shape"],
      "properties": {
        "atom_kind": { "$ref": "#/$defs/concept" },
        "element": { "enum": ["i8", "i16", "i24", "i32", "i64", "u8", "u16", "u32", "u64", "f16", "f32", "f64", "bool", "utf8", "bytes"] },
        "shape": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 1, "maximum": 18446744073709551615 } }
      }
    },
    "blob_integrity": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "digest"],
      "properties": {
        "algorithm": { "$ref": "#/$defs/concept" },
        "digest": { "$ref": "#/$defs/content_id" }
      }
    },
    "atom": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "presence", "payload"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "kind": { "enum": ["signal-block", "temporal-table", "table", "tensor", "encoded-block", "blob-ref"] },
        "presence": { "enum": ["present", "absent-at-source", "unknown-at-source", "withheld", "redacted", "not-applicable"] },
        "payload": { "oneOf": [{ "$ref": "#/$defs/payload" }, { "type": "null" }] },
        "time_axis": { "$ref": "#/$defs/time_axis" },
        "calibration": { "oneOf": [{ "$ref": "#/$defs/calibration" }, { "type": "null" }] },
        "clock_id": { "$ref": "#/$defs/object_id" },
        "record_kind": { "$ref": "#/$defs/concept" },
        "columns": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/table_column" } },
        "axes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/semantic_axis" } },
        "decoded_semantics": { "$ref": "#/$defs/decoded_semantics" },
        "media_type": { "type": "string", "pattern": "^[^/\\s]+/[^\\s]+$" },
        "integrity": { "$ref": "#/$defs/blob_integrity" }
      },
      "allOf": [
        {
          "if": { "properties": { "presence": { "const": "present" } }, "required": ["presence"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/payload" } } },
          "else": { "properties": { "payload": { "type": "null" } } }
        },
        { "if": { "properties": { "kind": { "const": "signal-block" } }, "required": ["kind"] }, "then": { "required": ["time_axis", "calibration"], "not": { "anyOf": [{ "required": ["clock_id"] }, { "required": ["record_kind"] }, { "required": ["columns"] }, { "required": ["axes"] }, { "required": ["decoded_semantics"] }, { "required": ["media_type"] }, { "required": ["integrity"] }] } } },
        { "if": { "properties": { "kind": { "const": "temporal-table" } }, "required": ["kind"] }, "then": { "required": ["clock_id", "record_kind", "columns"], "not": { "anyOf": [{ "required": ["time_axis"] }, { "required": ["calibration"] }, { "required": ["axes"] }, { "required": ["decoded_semantics"] }, { "required": ["media_type"] }, { "required": ["integrity"] }] } } },
        { "if": { "properties": { "kind": { "const": "table" } }, "required": ["kind"] }, "then": { "required": ["columns"], "not": { "anyOf": [{ "required": ["time_axis"] }, { "required": ["calibration"] }, { "required": ["clock_id"] }, { "required": ["record_kind"] }, { "required": ["axes"] }, { "required": ["decoded_semantics"] }, { "required": ["media_type"] }, { "required": ["integrity"] }] } } },
        { "if": { "properties": { "kind": { "const": "tensor" } }, "required": ["kind"] }, "then": { "required": ["axes"], "not": { "anyOf": [{ "required": ["time_axis"] }, { "required": ["calibration"] }, { "required": ["clock_id"] }, { "required": ["record_kind"] }, { "required": ["columns"] }, { "required": ["decoded_semantics"] }, { "required": ["media_type"] }, { "required": ["integrity"] }] } } },
        { "if": { "properties": { "kind": { "const": "encoded-block" } }, "required": ["kind"] }, "then": { "required": ["decoded_semantics"], "not": { "anyOf": [{ "required": ["time_axis"] }, { "required": ["calibration"] }, { "required": ["clock_id"] }, { "required": ["record_kind"] }, { "required": ["columns"] }, { "required": ["axes"] }, { "required": ["media_type"] }, { "required": ["integrity"] }] } } },
        { "if": { "properties": { "kind": { "const": "blob-ref" } }, "required": ["kind"] }, "then": { "required": ["media_type", "integrity"], "not": { "anyOf": [{ "required": ["time_axis"] }, { "required": ["calibration"] }, { "required": ["clock_id"] }, { "required": ["record_kind"] }, { "required": ["columns"] }, { "required": ["axes"] }, { "required": ["decoded_semantics"] }] } } }
      ]
    },
    "time_segment": {
      "type": "object", "additionalProperties": false,
      "required": ["start", "rate", "samples"],
      "properties": {
        "start": { "$ref": "#/$defs/rational" },
        "rate": { "$ref": "#/$defs/rational" },
        "samples": { "type": "integer", "minimum": 1, "maximum": 18446744073709551615 }
      }
    },
    "time_axis": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false, "required": ["regular"],
          "properties": { "regular": { "$ref": "#/$defs/time_segment" } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["piecewise"],
          "properties": { "piecewise": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/time_segment" } } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["explicit"],
          "properties": { "explicit": {
            "type": "object", "additionalProperties": false, "required": ["timestamps", "count"],
            "properties": {
              "timestamps": { "$ref": "#/$defs/content_id" },
              "count": { "type": "integer", "minimum": 1, "maximum": 18446744073709551615 }
            }
          } }
        }
      ]
    },
    "calibration": {
      "type": "object", "additionalProperties": false,
      "required": ["scale", "offset", "unit"],
      "properties": {
        "scale": { "$ref": "#/$defs/rational" },
        "offset": { "$ref": "#/$defs/rational" },
        "unit": { "$ref": "#/$defs/concept" }
      }
    },
    "clock": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "parent_id", "offset", "rate", "uncertainty"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "kind": { "$ref": "#/$defs/concept" },
        "parent_id": { "$ref": "#/$defs/nullable_object_id" },
        "offset": { "$ref": "#/$defs/rational" },
        "rate": { "$ref": "#/$defs/rational" },
        "uncertainty": { "$ref": "#/$defs/rational" }
      }
    },
    "clock_relation": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "from_clock_id", "to_clock_id", "offset", "rate", "uncertainty", "method", "validity_start", "validity_end", "provenance"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "from_clock_id": { "$ref": "#/$defs/object_id" },
        "to_clock_id": { "$ref": "#/$defs/object_id" },
        "offset": { "$ref": "#/$defs/rational" },
        "rate": { "$ref": "#/$defs/rational" },
        "uncertainty": { "$ref": "#/$defs/rational" },
        "method": { "$ref": "#/$defs/concept" },
        "validity_start": { "$ref": "#/$defs/rational" },
        "validity_end": { "oneOf": [{ "$ref": "#/$defs/rational" }, { "type": "null" }] },
        "provenance": { "$ref": "#/$defs/content_id" }
      }
    },
    "coordinate_frame": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "parent_id", "transform", "uncertainty"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "kind": { "$ref": "#/$defs/concept" },
        "parent_id": { "$ref": "#/$defs/nullable_object_id" },
        "transform": { "oneOf": [{ "type": "array", "minItems": 16, "maxItems": 16, "items": { "$ref": "#/$defs/exact" } }, { "type": "null" }] },
        "uncertainty": { "$ref": "#/$defs/rational" }
      }
    },
    "frame_transform": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "from_frame_id", "to_frame_id", "transform", "uncertainty", "method"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "from_frame_id": { "$ref": "#/$defs/object_id" },
        "to_frame_id": { "$ref": "#/$defs/object_id" },
        "transform": { "type": "array", "minItems": 16, "maxItems": 16, "items": { "$ref": "#/$defs/exact" } },
        "uncertainty": { "$ref": "#/$defs/rational" },
        "method": { "$ref": "#/$defs/concept" }
      }
    },
    "channel_basis": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "reference", "channels"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "channels": { "type": "array", "items": { "$ref": "#/$defs/channel" } },
        "reference": { "enum": ["absolute", "common", "differential", "unknown"] }
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "clock_id", "start", "end", "uncertainty"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "kind": { "$ref": "#/$defs/concept" },
        "clock_id": { "$ref": "#/$defs/object_id" },
        "start": { "$ref": "#/$defs/rational" },
        "end": { "$ref": "#/$defs/rational" },
        "uncertainty": { "$ref": "#/$defs/rational" }
      }
    },
    "policy": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "parent_id", "restrictions"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "parent_id": { "$ref": "#/$defs/nullable_object_id" },
        "restrictions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/concept" } }
      }
    },
    "proof": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "subject", "payload"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "kind": { "$ref": "#/$defs/concept" },
        "subject": { "$ref": "#/$defs/semantic_ref" },
        "payload": { "$ref": "#/$defs/content_id" }
      }
    },
    "derivation": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "operation", "inputs", "outputs"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "operation": { "$ref": "#/$defs/concept" },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/semantic_ref" } },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/semantic_ref" } }
      }
    },
    "derived_artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "content_id", "derivation_id"],
      "properties": {
        "id": { "$ref": "#/$defs/object_id" },
        "content_id": { "$ref": "#/$defs/content_id" },
        "derivation_id": { "$ref": "#/$defs/object_id" }
      }
    },
    "fidelity": {
      "type": "object", "additionalProperties": false,
      "required": ["subject", "kind", "metric", "bound"],
      "properties": {
        "subject": { "$ref": "#/$defs/semantic_ref" },
        "kind": { "enum": ["exact", "bounded", "transformed"] },
        "bound": { "oneOf": [{ "$ref": "#/$defs/exact" }, { "type": "null" }] },
        "metric": { "oneOf": [{ "$ref": "#/$defs/concept" }, { "type": "null" }] }
      }
    },
    "source_capsule": {
      "type": "object", "additionalProperties": false,
      "required": ["source", "content_id", "media_type"],
      "properties": {
        "source": { "$ref": "#/$defs/source_key" },
        "content_id": { "$ref": "#/$defs/content_id" },
        "media_type": { "type": ["string", "null"] }
      }
    },
    "execution": {
      "type": "object", "additionalProperties": false,
      "required": ["operation", "implementation", "hardware"],
      "properties": {
        "operation": { "$ref": "#/$defs/concept" },
        "implementation": { "type": "string" },
        "hardware": { "type": ["string", "null"] }
      }
    },
    "semantic_ref": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["dataset", "recording", "stream", "atom", "clock", "coordinate-frame", "channel-basis", "policy", "proof", "derivation", "subject", "patient", "session", "acquisition", "device", "sensor", "channel", "clock-relation", "frame-transform", "event", "concept-dictionary", "derived-artifact"] },
        "id": { "$ref": "#/$defs/object_id" }
      }
    },
    "channel": {
      "type": "object", "additionalProperties": false,
      "required": ["concept", "coordinate_frame_id", "source_keys"],
      "properties": {
        "concept": { "$ref": "#/$defs/concept" },
        "coordinate_frame_id": { "$ref": "#/$defs/nullable_object_id" },
        "source_keys": { "type": "array", "items": { "$ref": "#/$defs/source_key" } }
      }
    }
  }
}
