{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abir.quitetall.org/schema/bcs2-profile-v1.schema.json",
  "title": "BCS2 profile registry generation 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["generation", "wire_major", "id_family_prefixes", "profiles", "retired_ids"],
  "properties": {
    "generation": {"const": 1},
    "wire_major": {"const": 2},
    "id_family_prefixes": {
      "const": {"1": "lml", "2": "lmq", "3": "training", "4": "stream", "5": "forensic"}
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "root_kinds", "portable", "external_references"],
        "properties": {
          "id": {"type": "integer", "minimum": 1, "maximum": 4294967295},
          "name": {"type": "string", "pattern": "^bcs\\.[a-z0-9.-]+\\.v[1-9][0-9]*$"},
          "root_kinds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["dataset", "recording", "stream", "atom", "blob", "bundle"]}},
          "portable": {"type": "boolean"},
          "external_references": {"type": "boolean"}
        }
      }
    },
    "retired_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 4294967295}}
  }
}
