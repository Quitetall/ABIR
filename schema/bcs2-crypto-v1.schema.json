{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abir.quitetall.org/schema/bcs2-crypto-v1.schema.json",
  "title": "BCS2 cryptographic algorithm registry generation 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["generation", "wire_major", "algorithms", "retired_ids"],
  "properties": {
    "generation": {"const": 1},
    "wire_major": {"const": 2},
    "algorithms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "required_capability_bit", "nonce_bytes", "tag_bytes", "privacy_modes"],
        "properties": {
          "id": {"type": "integer", "minimum": 1, "maximum": 255},
          "name": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "required_capability_bit": {"type": "integer", "minimum": 0, "maximum": 63},
          "nonce_bytes": {"type": "integer", "minimum": 1, "maximum": 255},
          "tag_bytes": {"type": "integer", "minimum": 1, "maximum": 255},
          "privacy_modes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["encrypted_opaque", "encrypted_discoverable"]}
          }
        }
      }
    },
    "retired_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 255}}
  }
}
